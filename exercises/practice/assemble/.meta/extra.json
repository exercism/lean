[
  {
    "description": "Copy a value",
    "property": "assemble",
    "input": {
       "args": [10],
       "code": [
        "mov rax, rdi"
       ]
    },
    "expected": {
      "rax": 10
    }
  },
  {
    "description": "Sum and subtraction",
    "property": "assemble",
    "input": {
       "args": [10, 20],
       "code": [
        "mov rax, rdi",
        "add rax, rdi",
        "sub rax, rsi"
       ]
    },
    "expected": {
      "rax": 0
    }
  },
  {
    "description": "Multiplication and division",
    "property": "assemble",
    "input": {
      "args": [100, 5, 6],
      "code": [
        "mov rax, rdi",
        "mul rax, rdx",
        "div rax, rsi"
      ]
    },
    "expected": {
      "rax": 120
    }
  },
  {
    "description": "Bitwise operations",
    "property": "assemble",
    "input": {
       "args": [49, 16, 3, 255],
       "code": [
        "or rax, rcx",
        "and rax, rdi",
        "xor rax, rsi",
        "shr rax, 2",
        "shl rax, rdx"
       ]
    },
    "expected": {
      "rax": 64
    }
  },
  {
    "description": "Skip instructions",
    "property": "assemble",
    "input": {
       "args": [50000000000, -3000000000],
       "code": [
        "mov rax, rdi",
        "jmp end_program",
        "add rax, rsi",
        "end_program:"
       ]
    },
    "expected": {
      "rax": 50000000000
    }
  },
  {
    "description": "Condition met",
    "property": "assemble",
    "input": {
       "args": [40010, -40020],
       "code": [
        "mov rax, rdi",
        "cmp rax, rsi",
        "jg end_program",
        "add rax, rsi",
        "end_program:"
       ]
    },
    "expected": {
      "rax": 40010
    }
  },
  {
    "description": "Condition not met",
    "property": "assemble",
    "input": {
       "args": [400, -600],
       "code": [
        "mov rax, rdi",
        "cmp rax, rsi",
        "jl end_program",
        "add rax, rsi",
        "end_program:"
       ]
    },
    "expected": {
      "rax": -200
    }
  },
  {
    "description": "Registers are case-insensitive",
    "property": "assemble",
    "input": {
       "args": [4010, -3010],
       "code": [
        "mov RAX, rDi",
        "sub raX, RsI"
       ]
    },
    "expected": {
      "rax": 7020
    }
  },
  {
    "description": "Instructions are case-insensitive",
    "property": "assemble",
    "input": {
       "args": [-500, 10000, -80000],
       "code": [
        "MOV rax, rdi",
        "mUl rax, rdx",
        "diV rax, rsi",
        "ShR rax, 2"
       ]
    },
    "expected": {
      "rax": 1000
    }
  },
  {
    "description": "Labels are case-sensitive",
    "property": "assemble",
    "input": {
       "args": [4010, -3010, 10],
       "code": [
        "mov rax, rdi",
        "cmp rax, rsi",
        "jg End_program",
        "sub rax, rsi",
        "End_program:",
        "div rax, rdx",
        "end_program:"
       ]
    },
    "expected": {
      "rax": 401
    }
  },
  {
    "description": "All registers are used",
    "property": "assemble",
    "input": {
       "args": [4, -75590, -10, 890, 435, -235],
       "code": [
        "MOV RAX, R8",
        "ADD RAX, R9",
        "MUL RAX, RDX",
        "SUB RAX, RCX",
        "AND RAX, RDI",
        "OR RAX, RSI"
       ]
    },
    "expected": {
      "rax": -75586
    }
  },
  {
    "description": "Calculate the sum of the first 10 natural numbers",
    "property": "assemble",
    "input": {
       "args": [10],
       "code": [
        "Sum_first_N:",
        "Cmp Rdi, 0",
        "Je Base_case",
        "Add Rax, Rdi",
        "Sub Rdi, 1",
        "Jmp Sum_first_N",
        "Base_case:"
       ]
    },
    "expected": {
      "rax": 55
    }
  },
  {
    "description": "Count how many bits are set in 2000000000",
    "property": "assemble",
    "input": {
       "args": [2000000000],
       "code": [
        "pop_count:",
        "cmp rdi, 0",
        "je EXIT",
        "add rax, 1",
        "mov rdx, rdi",
        "sub rdx, 1",
        "and rdi, rdx",
        "jmp pop_count",
        "EXIT:"
       ]
    },
    "expected": {
      "rax": 13
    }
  },
  {
    "description": "Count steps in the Collatz Conjecture starting with 1000000, -1 indicates error",
    "property": "assemble",
    "input": {
       "args": [1000000],
       "code": [
        "steps:",
        "cmp rdi, 1",
        "jl error",
        "je EXIT",
        "loop:",
        "add rax, 1",
        "mov rdx, rdi",
        "and rdx, 1",
        "cmp rdx, 0",
        "je even",
        "mul rdi, 3",
        "add rdi, 1",
        "jmp loop",
        "even:",
        "shr rdi, 1",
        "cmp rdi, 1",
        "je EXIT",
        "jmp loop",
        "error:",
        "mov rax, -1",
        "EXIT:"
       ]
    },
    "expected": {
      "rax": 152
    }
  }
]
